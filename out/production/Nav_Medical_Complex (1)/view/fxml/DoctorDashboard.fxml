<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DoctorDashboardController"
            stylesheets="@../css/theme.css"
            prefWidth="1400" prefHeight="900">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="0" bottom="0" left="24" right="24"/></padding>
            <Label styleClass="topbar-logo" text="🏥"/>
            <VBox spacing="1">
                <Label styleClass="topbar-title" text="Nav Medical Complex"/>
                <Label styleClass="topbar-role"  text="DOCTOR PORTAL"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="20" alignment="CENTER">
                <VBox alignment="CENTER" spacing="1">
                    <Label fx:id="statMyPatients" styleClass="topstat-num" text="0"/>
                    <Label styleClass="topstat-lbl" text="My Patients"/>
                </VBox>
                <Label styleClass="topstat-div" text="|"/>
                <VBox alignment="CENTER" spacing="1">
                    <Label fx:id="statMyAppts" styleClass="topstat-num" text="0"/>
                    <Label styleClass="topstat-lbl" text="Appointments"/>
                </VBox>
                <Label styleClass="topstat-div" text="|"/>
                <VBox alignment="CENTER" spacing="1">
                    <Label fx:id="statAvailBadge" styleClass="topstat-num-green" text="Available"/>
                    <Label styleClass="topstat-lbl" text="Status"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" styleClass="topbar-welcome" text="Dr. Name"/>
            <Button fx:id="toggleAvailBtn" styleClass="btn-avail-on" text="Available" onAction="#toggleAvailability"/>
            <Button styleClass="btn-logout" text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <TabPane styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE">

            <Tab text="📅 My Schedule">
                <BorderPane styleClass="tab-content">
                    <center>
                        <VBox spacing="12">
                            <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label styleClass="tab-title" text="My Appointment Schedule"/>
                                <ComboBox fx:id="scheduleFilter" styleClass="input-field" prefWidth="160" promptText="Filter status"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <TableView fx:id="scheduleTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="scColId"       text="Appt"     prefWidth="90"/>
                                    <TableColumn fx:id="scColPatient"  text="Patient"  prefWidth="150"/>
                                    <TableColumn fx:id="scColDate"     text="Date"     prefWidth="100"/>
                                    <TableColumn fx:id="scColTime"     text="Time"     prefWidth="70"/>
                                    <TableColumn fx:id="scColReason"   text="Reason"   prefWidth="220"/>
                                    <TableColumn fx:id="scColPriority" text="Priority" prefWidth="85"/>
                                    <TableColumn fx:id="scColStatus"   text="Status"   prefWidth="100"/>
                                    <TableColumn fx:id="scColComplete" text="Action"   prefWidth="110"/>
                                </columns>
                                <placeholder><Label text="No appointments in your schedule." styleClass="table-placeholder"/></placeholder>
                            </TableView>
                            <VBox styleClass="form-panel" spacing="12">
                                <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                                <Label styleClass="form-title" text="Complete Appointment"/>
                                <Label styleClass="field-label" text="Select Appointment"/>
                                <ComboBox fx:id="completeApptCombo" styleClass="input-field" maxWidth="Infinity" promptText="Choose appointment"/>
                                <Label styleClass="field-label" text="Diagnosis"/>
                                <TextArea fx:id="diagnosisArea" styleClass="input-area"
                                          promptText="Enter diagnosis and observations..."
                                          prefHeight="100" wrapText="true"/>
                                <Button styleClass="btn-primary" text="Complete and Save"
                                        maxWidth="Infinity" onAction="#completeAppointment"/>
                                <Label fx:id="scheduleMsg" styleClass="form-msg" text="" wrapText="true"/>
                            </VBox>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>

            <Tab text="👥 My Patients">
                <BorderPane styleClass="tab-content">
                    <center>
                        <VBox spacing="12">
                            <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                            <Label styleClass="tab-title" text="My Assigned Patients"/>
                            <TableView fx:id="myPatientTable" styleClass="data-table" VBox.vgrow="ALWAYS"
                                       onMouseClicked="#onPatientSelected">
                                <columns>
                                    <TableColumn fx:id="mpColId"    text="ID"           prefWidth="80"/>
                                    <TableColumn fx:id="mpColName"  text="Name"         prefWidth="160"/>
                                    <TableColumn fx:id="mpColAge"   text="Age"          prefWidth="55"/>
                                    <TableColumn fx:id="mpColBlood" text="Blood"        prefWidth="65"/>
                                    <TableColumn fx:id="mpColAppts" text="Appointments" prefWidth="120"/>
                                    <TableColumn fx:id="mpColEmerg" text="Emergency"    prefWidth="90"/>
                                </columns>
                                <placeholder><Label text="No patients assigned yet." styleClass="table-placeholder"/></placeholder>
                            </TableView>
                            <VBox styleClass="form-panel" spacing="10">
                                <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                                <Label styleClass="form-title" text="Patient Detail"/>
                                <Label fx:id="detailName"    styleClass="detail-name"  text="Select a patient"/>
                                <Label fx:id="detailInfo"    styleClass="detail-info"  text=""/>
                                <Label fx:id="detailPhone"   styleClass="detail-muted" text=""/>
                                <Separator/>
                                <Label styleClass="field-label" text="Medical History"/>
                                <TextArea fx:id="historyArea" styleClass="history-area"
                                          editable="false" wrapText="true" prefHeight="120"/>
                                <Label styleClass="field-label" text="Add Note"/>
                                <TextField fx:id="quickNote" styleClass="input-field" promptText="Write a note for this patient"/>
                                <Button styleClass="btn-primary" text="Add Note"
                                        maxWidth="Infinity" onAction="#addQuickNote"/>
                                <Label fx:id="patientDetailMsg" styleClass="form-msg" text=""/>
                            </VBox>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>

            <Tab text="📝 Diagnoses">
                <BorderPane styleClass="tab-content">
                    <center>
                        <VBox spacing="12">
                            <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                            <Label styleClass="tab-title" text="Diagnosis Records"/>
                            <TableView fx:id="diagnosisTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="dgColDate"    text="Date"      prefWidth="130"/>
                                    <TableColumn fx:id="dgColPatient" text="Patient"   prefWidth="180"/>
                                    <TableColumn fx:id="dgColAppt"    text="Appt"      prefWidth="90"/>
                                    <TableColumn fx:id="dgColNotes"   text="Diagnosis/Notes" prefWidth="600"/>
                                    <TableColumn fx:id="dgColStatus"  text="Status"    prefWidth="100"/>
                                </columns>
                                <placeholder><Label text="No diagnoses recorded yet." styleClass="table-placeholder"/></placeholder>
                            </TableView>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>

            <Tab text="👤 My Profile">
                <ScrollPane fitToWidth="true" styleClass="form-scroll">
                    <VBox styleClass="profile-panel" spacing="16" maxWidth="600">
                        <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <Label styleClass="avatar-xl" text="👨‍⚕️"/>
                            <VBox spacing="4">
                                <Label fx:id="profileName"  styleClass="profile-name"  text="Dr. Name"/>
                                <Label fx:id="profileSpec"  styleClass="profile-spec"  text="Specialization"/>
                                <Label fx:id="profileQual"  styleClass="profile-qual"  text="Qualification"/>
                            </VBox>
                        </HBox>
                        <Separator/>
                        <Label styleClass="field-label" text="Email"/>
                        <Label fx:id="profileEmail" styleClass="profile-field-val" text=""/>
                        <Label styleClass="field-label" text="Phone"/>
                        <Label fx:id="profilePhone" styleClass="profile-field-val" text=""/>
                        <Label styleClass="field-label" text="Consultation Fee"/>
                        <Label fx:id="profileFee"   styleClass="profile-field-val" text=""/>
                        <Separator/>
                        <Label styleClass="form-title" text="Update Consultation Fee"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="newFeeField" styleClass="input-field" promptText="New fee (Rs)" prefWidth="180"/>
                            <Button styleClass="btn-primary" text="Update" onAction="#updateFee"/>
                        </HBox>
                        <Label fx:id="profileMsg" styleClass="form-msg" text=""/>
                    </VBox>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
